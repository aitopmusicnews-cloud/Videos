{
  "name": "music-video-studio",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node dev.js",
    "build": "vite build --config apps/web/vite.config.ts apps/web && esbuild apps/api/src/server.ts --bundle --platform=node --format=esm --packages=external --outfile=apps/api/dist/server.js",
    "start": "node apps/api/dist/server.js",
    "preview": "vite preview --config apps/web/vite.config.ts apps/web",
    "lint": "tsc -p apps/web/tsconfig.json --noEmit && tsc -p apps/api/tsconfig.json --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mvs/shared": "*",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.18",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.35",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.23.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "wavesurfer.js": "^7.8.6",
    "zod": "^3.23.8",
    "zustand": "^5.0.2"
  },
  "devDependencies": {}
}
