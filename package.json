{
  "name": "music-video-studio",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node dev.js",
    "clean": "node -e \"require('fs').rmSync('apps/web/dist',{recursive:true,force:true});require('fs').rmSync('apps/api/dist',{recursive:true,force:true});require('fs').rmSync('packages/shared/dist',{recursive:true,force:true})\"",
    "build": "npm run clean && npm run build --workspace @mvs/shared && npm run build --workspace @mvs/web && npm run build --workspace @mvs/api",
    "start": "npm run start --workspace @mvs/api",
    "preview": "npm run preview --workspace @mvs/web",
    "lint": "npm run typecheck --workspace @mvs/shared && npm run typecheck --workspace @mvs/web && npm run typecheck --workspace @mvs/api",
    "typecheck": "npm run lint"
  },
  "dependencies": {
    "@mvs/shared": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.2",
    "wavesurfer.js": "^7.8.6",
    "zustand": "^5.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.23.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.1"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10"
  }
}
