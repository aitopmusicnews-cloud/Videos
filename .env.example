# ==============================================================================
# MUSIC VIDEO STUDIO (MVS) - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Copy this file to '.env' in the project root and fill in your API credentials.
# Note: Keep your production '.env' secure and never commit it to source control.

# --- SERVER CONFIGURATION ---
# The port the backend server listens on (defaults to 3001 if omitted)
PORT=3001

# The external base URL of the backend API (used for resolving public assets)
PUBLIC_BASE_URL=https://rendernodock.onrender.com

# Comma-separated list of allowed CORS origins or a single URL for the frontend
WEB_ORIGIN=https://rendernodock.onrender.com

# --- PERSISTENCE & STORAGE ---
# STORAGE_BACKEND can be 'local' or 's3'.
#   - 'local': Files are written to STORAGE_DIR (best for development/local execution).
#   - 's3': Files are streamed directly to AWS S3 / CloudFront (best for production/serverless).
STORAGE_BACKEND=s3
STORAGE_DIR=s3://rendernodock-storage-052080186671-us-east-1-an/renders/

# --- AWS S3 BACKEND CONFIGURATION (Only required if STORAGE_BACKEND=s3) ---
# AWS Credentials are automatically loaded from standard environment variables:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
S3_BUCKET=rendernodock-storage-052080186671-us-east-1-an
S3_REGION=us-east-1
# Optional override for public S3 object URLs (e.g. CloudFront distribution domain)
S3_PUBLIC_URL_BASE=https://amazonaws.com

# --- PRODUCTION FRONTEND DISTRIBUTION ---
# Absolute or relative path to the built SPA (dist/ folder) to serve statically from `/`
# WEB_DIST_DIR=../web/dist

# --- AI GENERATION SERVICES (MODAL-POWERED / NO FAL OR OPENROUTER DEPENDENCIES) ---
# Endpoint URL for custom LTX-Video v2.3 model generation
MODAL_LTX_URL=https://cdtfullsail--mvs-ltx-video-generate.modal.run

# Endpoint URL for audio analysis (beat tracking, bpm, rms, onset detection)
MODAL_AUDIO_URL=https://cdtfullsail--music-video-studio-audio-analyze.modal.run

# Endpoint URL for Media Suite (Text-to-Image / SDXL)
MODAL_MEDIA_SUITE_URL=https://cdtfullsail--mvs-media-suite-text-to-image.modal.run

# Endpoint URL for Lip-Sync animation
MODAL_LIPSYNC_URL=

# Endpoint URL for media file resolver tracking
MODAL_FILE_RESOLVER_URL=

# --- OPTIONAL LOCAL INFERENCE SERVER FALLBACK ---
# Optional fallback URL if using a local Python inference server (local_server.py) instead of Modal
LOCAL_INFERENCE_URL=
