# Copy this file to .env for local development. Never commit real credentials.

# Server
PORT=3001
PUBLIC_BASE_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000
WEB_DIST_DIR=./apps/web/dist

# Storage: use local for development. Render can use S3 when every S3 variable is set.
STORAGE_BACKEND=local
STORAGE_DIR=./apps/api/storage
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PUBLIC_URL_BASE=

# Modal LTX-2.3 endpoint created by: modal deploy modal/ltx_video.py
MODAL_LTX_URL=https://YOUR-WORKSPACE--mvs-ltx-video-generate.modal.run

# Optional Modal proxy-token protection
MODAL_KEY=
MODAL_SECRET=

# Other optional Modal services
MODAL_AUDIO_URL=
MODAL_MEDIA_SUITE_URL=
MODAL_LIPSYNC_URL=
MODAL_FILE_RESOLVER_URL=

# Optional local inference fallback
LOCAL_INFERENCE_URL=
